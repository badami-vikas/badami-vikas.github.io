{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "zazoo-operating-brief-api",
  "main": "src/index.mjs",
  "compatibility_date": "2026-07-23",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zazoo-operating-brief",
      "database_id": "9b52de77-954c-45f8-b5fc-5c78720289a2"
    }
  ]
}
